{
	"name": "edt",
	"displayName": "edt",
	"version": "0.0.1",
	"description": "use cmd+alt+p to list open editors, cmd+ctrl+p to quick open file path",
	"categories": [
		"Other"
	],
	"author": {
		"name": "talovsky"
	},
	"type": "module",
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "bun run build",
		"build": "bun run clean && tsc -p ./",
		"clean": "rm -rf out",
		"watch": "tsc -p ./ --watch",
		"lint": "oxfmt && oxlint"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/vscode": "^1.104.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"typescript": "^6"
	},
	"contributes": {
		"commands": [
			{
				"command": "edt.edt",
				"title": "Show opened editors"
			},
			{
				"command": "edt.path",
				"title": "Show Quick Open with the path of the current editor"
			}
		],
		"keybindings": [
			{
				"key": "alt+cmd+p",
				"mac": "alt+cmd+p",
				"command": "edt.edt"
			},
			{
				"key": "ctrl+cmd+p",
				"mac": "ctrl+cmd+p",
				"command": "edt.path"
			}
		]
	},
	"activationEvents": [],
	"engines": {
		"vscode": "^1.104.0"
	}
}
