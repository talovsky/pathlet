{
	"name": "pathlet",
	"displayName": "Pathlet",
	"version": "1.0.0",
	"description": "Ditch tabs and use Quick Open to navigate between opened editors and the file system",
	"categories": [
		"Other"
	],
	"author": {
		"name": "talovsky"
	},
	"type": "module",
	"main": "./out/extension.js",
	"publisher": "talovsky",
		"repository": {
		"type": "git",
		"url": "https://github.com/talovsky/pathlet.git"
	},
	"icon": "./pathlet.png",

	"scripts": {
		"vscode:prepublish": "bun run build",
		"build": "rm -rf out && tsc -p ./",
		"watch": "tsc -p ./ --watch",
		"lint": "oxfmt && oxlint"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/vscode": "^1.100.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"typescript": "^6"
	},
	"contributes": {
		"commands": [
			{
				"command": "pathlet.opened",
				"title": "Show opened editors"
			},
			{
				"command": "pathlet.pwd",
				"title": "Show Quick Open with the path of the current editor"
			}
		],
		"keybindings": [
			{
				"key": "alt+ctrl+p",
				"mac": "alt+cmd+p",
				"command": "pathlet.opened"
			},
			{
				"key": "ctrl+ctrl+p",
				"mac": "ctrl+cmd+p",
				"command": "pathlet.pwd"
			}
		]
	},
	"activationEvents": [],
	"engines": {
		"vscode": "^1.100.0"
	}
}
