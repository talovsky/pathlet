{
	"name": "pathlet",
	"displayName": "Pathlet",
	"version": "1.0.0",
	"description": "Ditch tabs and use Quick Open to navigate between opened editors and the file system",
	"categories": [
		"Other"
	],
	"author": {
		"name": "talovsky"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/talovsky/pathlet.git"
	},
	"publisher": "talovsky",
	"type": "module",
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "bun run build",
		"build": "rm -rf out && tsc -p ./",
		"watch": "tsc -p ./ --watch",
		"lint": "oxfmt && oxlint",
		"prepare": "husky",
		"typecheck": "tsc tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/vscode": "^1.100.0",
		"husky": "^9.1.7",
		"nano-staged": "^1.0.2",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"oxlint-tsgolint": "^0.22.0",
		"typescript": "^6"
	},
	"nano-staged": {
		"*.ts": [
			"oxfmt",
			"oxlint"
		],
		"*.{md,json}": [
			"oxfmt"
		]
	},
	"contributes": {
		"commands": [
			{
				"command": "pathlet.opened",
				"title": "Show opened editors"
			},
			{
				"command": "pathlet.pwd",
				"title": "Show Quick Open with the path of the current editor"
			}
		],
		"keybindings": [
			{
				"key": "alt+ctrl+p",
				"mac": "alt+cmd+p",
				"command": "pathlet.opened"
			},
			{
				"key": "ctrl+ctrl+p",
				"mac": "ctrl+cmd+p",
				"command": "pathlet.pwd"
			}
		]
	},
	"activationEvents": [],
	"icon": "./pathlet.png",
	"engines": {
		"vscode": "^1.100.0"
	}
}
